---
// ============================================================================
// LOGO STRIP
// ============================================================================
//
// Drop client logo files into `src/assets/logos/` and they're available here.
//
//   • SVGs   → rendered inline as <svg> (inherit currentColor, stylable)
//   • PNG/JPG/WebP → rendered via <Image> (optimized, hashed)
//
// Filename (without extension) is used as alt text. Use `-` or `_` for spaces:
// `acme-corp.svg` → "acme corp".
//
// CONTROLLING WHICH LOGOS APPEAR + IN WHAT ORDER
// ----------------------------------------------------------------------------
// By default, all logos in the folder render alphabetically. To pick a subset
// or set an explicit order, pass the `order` prop with filename stems (no
// extension) in the order you want them displayed:
//
//   <LogoStrip order={["acme", "globex", "initech"]} />
//
// Any name in `order` that doesn't match a file is silently skipped.
// Without the prop, every logo in the folder is shown alphabetically.
// ============================================================================

import { Image } from "astro:assets";
import type { ImageMetadata, SvgComponent } from "astro/types";

interface Props {
  order?: string[];
  heading?: string;
}

const { order, heading = "Loved by developers at fast-moving teams" } =
  Astro.props;

const svgModules = import.meta.glob<{ default: SvgComponent }>(
  "../assets/logos/*.svg",
  { eager: true },
);

const rasterModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/logos/*.{png,jpg,jpeg,webp}",
  { eager: true },
);

const stemFromPath = (path: string) =>
  path.split("/").pop()!.replace(/\.[^.]+$/, "");

const prettify = (stem: string) => stem.replace(/[-_]/g, " ");

type LogoEntry =
  | { kind: "svg"; stem: string; name: string; Component: SvgComponent }
  | { kind: "raster"; stem: string; name: string; src: ImageMetadata };

// Build a lookup of every available logo, keyed by filename stem.
const allLogos = new Map<string, LogoEntry>();

for (const [path, mod] of Object.entries(svgModules)) {
  const stem = stemFromPath(path);
  allLogos.set(stem, {
    kind: "svg",
    stem,
    name: prettify(stem),
    Component: mod.default,
  });
}

for (const [path, mod] of Object.entries(rasterModules)) {
  const stem = stemFromPath(path);
  allLogos.set(stem, {
    kind: "raster",
    stem,
    name: prettify(stem),
    src: mod.default,
  });
}

// If `order` is provided, use it (skipping unknown names).
// Otherwise show every logo, alphabetically.
const logos: LogoEntry[] = order
  ? order
      .map((stem) => allLogos.get(stem))
      .filter((entry): entry is LogoEntry => entry !== undefined)
  : Array.from(allLogos.values()).sort((a, b) =>
      a.stem.localeCompare(b.stem),
    );
---

<section class="border-y border-line/60 bg-bg/60 py-12">
  <div class="container-page">
    <p class="mb-8 text-center font-mono text-[11px] uppercase tracking-[0.2em] text-fg-subtle">
      {heading}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 text-fg-subtle">
      {
        logos.map((logo) =>
          logo.kind === "svg" ? (
            <logo.Component
              role="img"
              aria-label={logo.name}
              class="h-8 w-auto"
            />
          ) : (
            <Image
              src={logo.src}
              alt={logo.name}
              class="h-8 w-auto object-contain"
            />
          ),
        )
      }
    </div>
  </div>
</section>

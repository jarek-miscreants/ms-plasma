---
// ============================================================================
// LOGO STRIP — source-agnostic "Trusted by" component
// ============================================================================
//
// Renders the array from src/data/logos.ts. Each entry has a `kind` field
// that determines how it's rendered:
//
//   "iconify"  → <Icon> component from astro-icon (Iconify brand collection)
//   "svg"      → <Image> component from astro:assets (vector file in src/)
//   "image"    → <Image> component from astro:assets (raster file in src/)
//   "inline"   → raw <svg> with set:html (placeholder / one-off)
//
// Adding a new logo = adding one entry to logos.ts. The component never
// needs to change as long as the source is one of these four kinds.
// ============================================================================

import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { logos } from "../data/logos";
---

<section class="border-y border-line/60 bg-bg/60 py-12">
  <div class="container-page">
    <p class="mb-8 text-center font-mono text-[11px] uppercase tracking-[0.2em] text-fg-subtle">
      Loved by developers at fast-moving teams
    </p>

    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
      {
        logos.map((logo) => {
          // Wrap in <a> if there's a url, otherwise <div>.
          // Same inner content either way.
          const Tag = logo.url ? "a" : "div";
          const linkProps = logo.url
            ? { href: logo.url, target: "_blank", rel: "noopener noreferrer" }
            : {};

          return (
            <Tag
              {...linkProps}
              class="flex items-center gap-2 text-fg-subtle transition hover:text-fg"
            >
              {/* Branch once per source kind. TypeScript narrows correctly inside each. */}
              {logo.kind === "iconify" && (
                <Icon name={logo.slug} class="h-5 w-5" />
              )}

              {logo.kind === "svg" && (
                <Image
                  src={logo.src}
                  alt={logo.name}
                  class="h-5 w-auto object-contain"
                />
              )}

              {logo.kind === "image" && (
                <Image
                  src={logo.src}
                  alt={logo.name}
                  class="h-5 w-auto object-contain"
                />
              )}

              {logo.kind === "inline" && (
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  set:html={logo.svg}
                />
              )}

              <span class="font-sans text-base font-semibold tracking-tight">
                {logo.name}
              </span>
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>

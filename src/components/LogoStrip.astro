---
// Stylized brand monograms — each is a small SVG mark + wordmark.
// Render as currentColor so the strip stays monochrome and inherits hover.

const logos = [
  {
    name: "Linear",
    svg: `<rect x="2" y="2" width="20" height="20" rx="4" fill="none" stroke="currentColor" stroke-width="2"/><path d="M7 13L11 17L17 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    name: "Vercel",
    svg: `<path d="M12 3L22 20H2L12 3Z" fill="currentColor"/>`,
  },
  {
    name: "Notion",
    svg: `<rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M8 8L16 16M8 8V16M16 8V16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    name: "Supabase",
    svg: `<path d="M12 2L4 14H12V22L20 10H12L12 2Z" fill="currentColor"/>`,
  },
  {
    name: "Stripe",
    svg: `<rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M3 10H21" stroke="currentColor" stroke-width="2"/><path d="M7 15H10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,
  },
  {
    name: "Cloudflare",
    svg: `<ellipse cx="12" cy="14" rx="9" ry="5" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="16" cy="9" r="3" fill="none" stroke="currentColor" stroke-width="2"/>`,
  },
  {
    name: "Railway",
    svg: `<rect x="3" y="6" width="18" height="12" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="8" cy="16" r="1.5" fill="currentColor"/><circle cx="16" cy="16" r="1.5" fill="currentColor"/>`,
  },
];
---

<section class="border-y border-line/60 bg-bg/60 py-12">
  <div class="container-page">
    <p class="mb-8 text-center font-mono text-[11px] uppercase tracking-[0.2em] text-fg-subtle">
      Loved by developers at fast-moving teams
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
      {
        logos.map((logo) => (
          <div class="flex items-center gap-2 text-fg-subtle transition hover:text-fg">
            <svg viewBox="0 0 24 24" class="h-5 w-5" set:html={logo.svg} />
            <span class="font-sans text-base font-semibold tracking-tight">
              {logo.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

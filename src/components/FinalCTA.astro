---
import Logo from "./Logo.astro";
// Final CTA — big centered "Install it. script it. forget it. forever."
// with strong purple gradient background (mirrors the hero aurora).
---

<section class="relative overflow-hidden py-section">
  <!-- Strong purple gradient background, mirrored from hero -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <!-- Top fade in from bg -->
    <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-bg to-transparent"></div>
    <!-- Main aurora -->
    <div
      class="absolute inset-x-0 bottom-0 h-[600px]"
      style="background:
        radial-gradient(ellipse 60% 70% at 50% 100%, rgb(232 121 249 / 0.5), transparent 60%),
        radial-gradient(ellipse 80% 60% at 30% 100%, rgb(168 85 247 / 0.55), transparent 65%),
        radial-gradient(ellipse 80% 60% at 70% 100%, rgb(217 70 239 / 0.45), transparent 65%),
        radial-gradient(ellipse 100% 80% at 50% 100%, rgb(126 34 206 / 0.35), transparent 75%);"
    ></div>
    <!-- Grid pattern on top -->
    <div class="grid-bg absolute inset-0"></div>
  </div>

  <div class="container-page relative flex flex-col items-center gap-8 text-center">
    <!-- Logo mark -->
    <Logo class="h-8 w-auto text-fg" />


    <!-- Big headline -->
    <h2
      class="font-sans font-extrabold tracking-tight text-fg"
      style="font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1; letter-spacing: -0.045em;"
    >
      Install it. <span class="text-gradient">script it.</span><br />
      forget it. forever.
    </h2>

    <p class="max-w-xl text-base text-fg-muted">
      Plasma is free, open source, and runs entirely on your machine. Install
      once and your automations keep working — no cloud, no subscription, no
      surveillance.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-3">
      <a href="#" class="btn-primary">
        Try it locally
        <span aria-hidden="true">→</span>
      </a>
      <a href="#" class="btn-secondary">
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.8 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.05.78 2.13v3.16c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <p class="font-mono text-xs text-fg-subtle">
      <span class="text-fg-muted">2.4k</span> stars ·
      <span class="text-fg-muted">500+</span> active installs
    </p>
  </div>
</section>

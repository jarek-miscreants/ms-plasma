---
import Logo from "./Logo.astro";

const navColumns = [
  { title: "Product", links: ["Features", "Pricing", "Download", "Changelog", "Roadmap"] },
  { title: "Company", links: ["About", "Blog", "Careers", "Press", "Contact"] },
  { title: "Resources", links: ["Docs", "Guides", "Examples", "Community", "Support"] },
];

const socialIcons = [
  {
    label: "Instagram",
    path: "M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.2 1.8-.4 2.2a3.7 3.7 0 0 1-2.3 2.3c-.4.2-1 .4-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.8-.2-2.2-.4a3.7 3.7 0 0 1-2.3-2.3c-.2-.4-.4-1-.4-2.2-.1-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c0-1.2.2-1.8.4-2.2a3.7 3.7 0 0 1 2.3-2.3c.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 5.3a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9zm5.4-.7a1 1 0 1 0 0 2 1 1 0 0 0 0-2zM12 9.3a2.7 2.7 0 1 1 0 5.4 2.7 2.7 0 0 1 0-5.4z",
  },
  {
    label: "X (Twitter)",
    path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231L18.244 2.25Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z",
  },
  {
    label: "GitHub",
    path: "M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.8 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.05.78 2.13v3.16c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z",
  },
];
---

<footer class="border-t border-line bg-bg">
  <div class="container-page py-16">
    <div class="grid gap-12 md:grid-cols-[1.5fr_2fr]">
      <!-- Brand block -->
      <div class="flex flex-col gap-6">
        <a
          href="/"
          class="block w-fit text-fg transition hover:text-violet-bright"
          aria-label="Miscreants home"
        >
          <Logo class="h-9 w-auto" />
        </a>
        <p class="max-w-sm text-sm text-fg-muted">
          Local-first automation for power users. Open source. No cloud.
          <span class="text-fg">Yours forever.</span>
        </p>

        <!-- Newsletter / stay-in-touch -->
        <form
          class="flex w-full max-w-sm items-center gap-2 rounded-md border border-line-strong bg-bg-elevated p-1.5 focus-within:border-violet/50"
          onsubmit="event.preventDefault();"
        >
          <input
            type="email"
            placeholder="you@company.com"
            class="flex-1 bg-transparent px-2 text-sm text-fg placeholder:text-fg-subtle focus:outline-none"
          />
          <button type="submit" class="btn-primary !px-3 !py-1.5 !text-xs">
            Subscribe
          </button>
        </form>

        <!-- Social + small stats -->
        <div class="flex items-center gap-5">
          <div class="flex gap-2">
            {
              socialIcons.map((social) => (
                <a
                  href="#"
                  aria-label={social.label}
                  class="grid h-9 w-9 place-items-center rounded-md border border-line text-fg-muted transition hover:border-violet/40 hover:text-fg"
                >
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
                    <path d={social.path} />
                  </svg>
                </a>
              ))
            }
          </div>
          <span class="font-mono text-[11px] text-fg-subtle">
            <span class="text-fg">2.4k</span> stars ·
            <span class="text-fg">500+</span> installs
          </span>
        </div>
      </div>

      <!-- Nav columns -->
      <nav class="grid grid-cols-2 gap-8 sm:grid-cols-3">
        {
          navColumns.map((col) => (
            <div class="flex flex-col gap-3">
              <h3 class="font-mono text-[11px] uppercase tracking-[0.15em] text-fg-subtle">
                {col.title}
              </h3>
              <ul class="flex flex-col gap-2">
                {col.links.map((link) => (
                  <li>
                    <a
                      href="#"
                      class="text-sm text-fg-muted transition hover:text-fg"
                    >
                      {link}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-line pt-6 sm:flex-row sm:items-center">
      <p class="font-mono text-xs text-fg-subtle">
        © {new Date().getFullYear()} Plasma — Built for builders.
      </p>
      <div class="flex gap-4 font-mono text-xs text-fg-subtle">
        <a href="#" class="transition hover:text-fg-muted">Privacy</a>
        <a href="#" class="transition hover:text-fg-muted">Terms</a>
        <a href="#" class="transition hover:text-fg-muted">Status</a>
      </div>
    </div>
  </div>
</footer>
